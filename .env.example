# ─────────────────────────────────────────────────────────────
# App
# ─────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001
APP_URL=http://localhost:3000          # web admin dev URL

# ─────────────────────────────────────────────────────────────
# Supabase — hosted database + auth (never run locally)
# Get all values from: Supabase dashboard → Settings → API
# ─────────────────────────────────────────────────────────────
SUPABASE_URL=                          # https://<project>.supabase.co
SUPABASE_ANON_KEY=                     # safe for mobile/web clients
SUPABASE_SERVICE_ROLE_KEY=             # API server only — NEVER expose to clients
SUPABASE_JWT_SECRET=                   # Settings → API → JWT Secret
                                       # Used by the API to verify Supabase-issued JWTs

# ─────────────────────────────────────────────────────────────
# Twilio (emergency SMS)
# ─────────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# ─────────────────────────────────────────────────────────────
# Firebase (push notifications via FCM)
# ─────────────────────────────────────────────────────────────
FCM_SERVER_KEY=
GOOGLE_APPLICATION_CREDENTIALS=       # path to Firebase service account JSON

# ─────────────────────────────────────────────────────────────
# Cloudinary (images, videos, badge certificates)
# ─────────────────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ─────────────────────────────────────────────────────────────
# Google Maps
# ─────────────────────────────────────────────────────────────
GOOGLE_MAPS_API_KEY=

# ─────────────────────────────────────────────────────────────
# Encryption — AES-256-GCM for journal entries + cycle notes
# Generate: openssl rand -hex 32
# ─────────────────────────────────────────────────────────────
ENCRYPTION_KEY=

# ─────────────────────────────────────────────────────────────
# Redis (runs locally via docker compose)
# ─────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─────────────────────────────────────────────────────────────
# AI content moderation (optional — human review is always on)
# ─────────────────────────────────────────────────────────────
OPENAI_API_KEY=                        # used only for Moderation API — not for generative AI

# ─────────────────────────────────────────────────────────────
# Monitoring
# ─────────────────────────────────────────────────────────────
SENTRY_DSN=                             # API server Sentry DSN

# ─────────────────────────────────────────────────────────────
# Web admin (Next.js — prefix NEXT_PUBLIC_ for browser-safe vars)
# ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=              # same as SUPABASE_URL
NEXT_PUBLIC_SUPABASE_ANON_KEY=         # same as SUPABASE_ANON_KEY
NEXT_PUBLIC_API_URL=http://localhost:3001/api/v1
API_URL=http://localhost:3001/api/v1   # server-side only

# ─────────────────────────────────────────────────────────────
# GitHub Actions secrets (set in repo Settings → Secrets)
# ─────────────────────────────────────────────────────────────
# RAILWAY_TOKEN=           (from Railway dashboard)
# VERCEL_TOKEN=            (from Vercel dashboard)
# VERCEL_ORG_ID=
# VERCEL_PROJECT_ID=
# SUPABASE_ACCESS_TOKEN=   (from Supabase account settings)
# SUPABASE_PROJECT_REF=    (e.g. abcdefghijklmnop)
