{
  "expo": {
    "name": "Njoum",
    "slug": "njoum",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#FDF6F0"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "app.njoum.mobile",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Njoum needs your location to share it with your emergency contacts during an SOS.",
        "NSLocationAlwaysUsageDescription": "Njoum needs background location during an active SOS event.",
        "NSMotionUsageDescription": "Njoum can trigger SOS when it detects a fall or shake."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#FDF6F0"
      },
      "package": "app.njoum.mobile",
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "RECEIVE_BOOT_COMPLETED",
        "VIBRATE"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#B5586A",
          "sounds": []
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Njoum needs your location to share it with emergency contacts during an SOS."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "scheme": "njoum",
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "YOUR_EAS_PROJECT_ID"
      }
    }
  }
}
